# 7RANSMI7 — Local env placeholders (no secrets in git)
PORT=8787
# Frontend API origin (no trailing slash).
# Dev: omit to use the Vite `/api` proxy (empty base). Or set http://localhost:8787.
# Prod builds default to https://sevenransmi7.onrender.com when unset.
# VITE_API_BASE_URL=http://localhost:8787

# Required in production / on Render (min 16 chars).
# In development/test only, a documented local default is used if unset.
SESSION_SECRET=change-me-to-a-long-random-string

# When true (or when RENDER is set), trust X-Forwarded-For / X-Real-IP for rate limits.
# Leave unset for local node so clients cannot spoof the rate-limit bucket.
TRUST_PROXY=

# Comma-separated browser origins allowed for CORS (credentials).
# Defaults: GitHub Pages + local Vite.
# ALLOWED_ORIGINS=https://rrkher059-cloud.github.io,http://localhost:5173

# Force Secure + SameSite=None cookies (also enabled when NODE_ENV=production or RENDER).
COOKIE_SECURE=

# Public site URL used as OpenRouter HTTP-Referer.
PUBLIC_APP_URL=http://localhost:5173

# Test-only: fixed OTP for auth tests. Honored only when NODE_ENV=test.
# Never set in production — the server refuses to boot if you do.
# AUTH_TEST_OTP=123456

# Optional — without this, verification codes print to the API console
# (never in production).
RESEND_API_KEY=
RESEND_FROM=7RANSMI7 <onboarding@resend.dev>

# OpenRouter — server-only (never expose to Vite / the browser).
OPENROUTER_API_KEY=
# Optional model override (default: openai/gpt-4o-mini)
OPENROUTER_MODEL=openai/gpt-4o-mini
