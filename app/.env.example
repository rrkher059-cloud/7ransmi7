# 7RANSMI7 — Local env placeholders (no secrets in git)
PORT=8787
VITE_API_BASE_URL=/api

# Required in production (min 16 chars). Dev falls back to a local default.
SESSION_SECRET=change-me-to-a-long-random-string

# Optional — without this, verification codes print to the API console.
RESEND_API_KEY=
RESEND_FROM=7RANSMI7 <onboarding@resend.dev>

# OpenRouter — server-only (never expose to Vite / the browser).
OPENROUTER_API_KEY=
# Optional model override (default: openai/gpt-4o-mini)
OPENROUTER_MODEL=openai/gpt-4o-mini
